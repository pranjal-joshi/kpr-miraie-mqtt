mqtt:
  host: 192.168.1.100          # your local MQTT broker IP
  port: 1883
  username: mqtt              # your MQTT broker username
  password: changeme          # your MQTT broker password

ha_discovery_prefix: homeassistant

cloud:
  broker: mqtt.miraie.in
  port: 8883

# STEP 1: Leave devices empty and run the bridge to discover your device IDs:
#   python3 miraie_bridge.py
# It will print the device config to paste here.
#
# STEP 2: Paste the discovered devices below and restart the bridge.
devices:
  # - name: Living Room AC
  #   slug: kpr_xxxxxxxxxxxx
  #   space: Living Room
  #   device_id: xxxxxxxxxxxx
  #   manufacturer: KPR
  #   model: Panasonic MirAIe Smart AC
